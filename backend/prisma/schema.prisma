generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  LAWYER
  CLIENT
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

model User {
  id         String   @id @default(cuid())
  firstName  String
  lastName   String
  email      String   @unique

  password   String?

  role       Role     @default(LAWYER)

  inviteToken   String?   @unique
  inviteExpires DateTime?

  lawyerCases Case[] @relation("LawyerCases")
  clientCases Case[] @relation("ClientCases")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Case {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      CaseStatus @default(OPEN)

  lawyerId String
  lawyer   User @relation("LawyerCases", fields: [lawyerId], references: [id])

  clientId String
  client   User @relation("ClientCases", fields: [clientId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}