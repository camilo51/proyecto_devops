generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CaseStatus {
  PENDING
  IN_PROGRESS
  CLOSED
}

model User {
  id          String       @id @default(uuid())
  firstName   String
  lastName    String
  email       String       @unique
  password    String
  invitations Invitation[]
  clients     Client[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Invitation {
  id         String    @id @default(uuid())
  token      String    @unique
  email      String    @unique
  expiresAt  DateTime
  used       Boolean   @default(false)
  lawyerId   String
  lawyer     User      @relation(fields: [lawyerId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([lawyerId])
}

model Client {
  id         String     @id @default(uuid())
  firstName  String
  lastName   String
  email      String     @unique
  phone      String?
  password   String
  isActive   Boolean    @default(true)
  lawyerId   String
  lawyer     User       @relation(fields: [lawyerId], references: [id], onDelete: Cascade)
  cases      Case[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([lawyerId])
}

model Case {
  id          String      @id @default(uuid())
  title       String
  description String
  status      CaseStatus  @default(PENDING)
  clientId    String
  client      Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([clientId])
}